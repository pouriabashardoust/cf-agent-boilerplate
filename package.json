{
  "name": "agent-boilerplate",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names worker,ui --prefix-colors blue,magenta --kill-others-on-fail \"npm:dev:worker\" \"npm:dev:ui\"",
    "dev:worker": "wrangler dev --port 8787 --inspector-port 8788",
    "dev:ui": "npm --prefix chat-ui run dev",
    "build:ui": "npm --prefix chat-ui run build",
    "start": "npm run build:ui && npm run dev:worker",
    "deploy": "npm run build:ui && wrangler deploy",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.75",
    "@cloudflare/think": "^0.1.0",
    "@neondatabase/serverless": "^1.1.0",
    "@posthog/ai": "^7.17.5",
    "agents": "^0.9.0",
    "ai": "^6.0.0",
    "posthog-node": "^5.33.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
