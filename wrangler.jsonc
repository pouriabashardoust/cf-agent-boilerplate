{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-boilerplate",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-05",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      { "class_name": "ChatAgent", "name": "ChatAgent" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ChatAgent"] }
  ],
  // Worker Loader binding — lets the agent run dynamically-supplied code in a
  // sandbox, with the SLACK / DATABASE entrypoints injected as env bindings.
  "worker_loaders": [{ "binding": "LOADER" }],
  // *.sandbox.js — sandbox source code shipped to env.LOADER (text, not code).
  // *.html — playground UI served verbatim from the worker fetch handler.
  "rules": [
    { "type": "Text", "globs": ["**/*.sandbox.js", "**/*.html"], "fallthrough": false }
  ]
}
