{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-boilerplate",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-05",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      { "class_name": "ChatAgent", "name": "ChatAgent" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ChatAgent"] }
  ],
  // Worker Loader binding — lets the agent run dynamically-supplied code in a
  // sandbox, with the SLACK / DATABASE entrypoints injected as env bindings.
  "worker_loaders": [{ "binding": "LOADER" }],
  // *.sandbox.js — sandbox source code shipped to env.LOADER (text, not code).
  "rules": [
    { "type": "Text", "globs": ["**/*.sandbox.js"], "fallthrough": false }
  ],
  // Static UI bundle. Run `pnpm --dir chat-ui build` before `wrangler dev`/`deploy`.
  // The Worker only handles requests not matched by an asset (`run_worker_first: false`),
  // so `/api/*` and `/agents/*` keep flowing to fetch().
  "assets": {
    "directory": "chat-ui/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
